{
  "go.toolsManagement.autoUpdate": true,
  "go.useLanguageServer": true,
  "go.formatTool": "goimports",
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "package",
  "go.vulncheck.OnSave": "Imports",
  "go.toolsManagement.autoUpdate": true,
  "go.diagnostic.vulncheck": "Imports",
  "go.buildOnSave": "off",
  "go.testOnSave": false,
  "go.coverOnSave": false,
  "go.coverageDecorator": {
    "type": "gutter",
    "coveredHighlightColor": "rgba(64,128,128,0.5)",
    "uncoveredHighlightColor": "rgba(128,64,64,0.25)"
  },
  "go.testFlags": ["-v"],
  "go.buildTags": "",
  "go.testTimeout": "30s",
  "go.generateTestsFlags": ["-exported"],
  "go.addTags": {
    "tags": "json",
    "options": "json=omitempty",
    "prompt": true,
    "transform": "snakecase"
  },
  "go.removeTags": {
    "tags": "json",
    "options": "json=omitempty",
    "prompt": true
  },
  "go.fillStruct": {
    "snakecase": true
  },
  "go.inferGopath": false,
  "go.gocodeAutoBuild": false,
  "go.toolsManagement.autoUpdate": true,
  "go.useLanguageServer": true,
  "go.languageServerExperimentalWorkspaceModule": true,
  "go.diagnostic.vulncheck": "Imports",
  "go.survey.prompt": false,
  "go.welcomeToGoDialogShown": true,
  "go.editorContextMenuCommands": {
    "toggleTestFile": true,
    "addTags": true,
    "removeTags": true,
    "fillStruct": true,
    "testAtCursor": true,
    "testFile": true,
    "testPackage": true,
    "generateTestForFunction": true,
    "generateTestForFile": true,
    "generateTestForPackage": true,
    "addImport": true,
    "testCoverage": true,
    "playground": true,
    "debugTestAtCursor": true,
    "benchmarkAtCursor": true
  }
}
